# Copy to .env and fill in. chmod 600 .env. Gitignored; never commit real values.

# Encrypts the vault store at rest (only protects a cold/stolen volume, not a live host).
# Generate:  echo "AGENT_VAULT_MASTER_PASSWORD=$(openssl rand -hex 16)" >> .env
AGENT_VAULT_MASTER_PASSWORD=

# Minted in the vault UI (Agents -> Add agent -> default, role: proxy). Agent won't start without it.
AGENT_VAULT_TOKEN=
